# Copy to .env and fill in your secrets. Anything not set falls back to the
# default in backend/config.py.

# ---- Required ----------------------------------------------------------

# Gemini API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Mathpix credentials from https://accounts.mathpix.com/dashboard
# Only needed when a chosen template flags any question as type=diagram
# (currently: seamo_x_2026_a, seamo_x_2026_b).
MATHPIX_APP_ID=your_mathpix_app_id_here
MATHPIX_APP_KEY=your_mathpix_app_key_here

# ---- Gemini model selection -------------------------------------------

# Primary model. gemini-2.5-pro reads handwriting best but has lower RPM on
# free tier; gemini-2.0-flash is faster and has much higher RPM headroom.
GEMINI_MODEL=gemini-2.5-pro
GEMINI_FALLBACK_MODELS=gemini-2.5-flash,gemini-flash-latest
GEMINI_AUTO_FALLBACK=True

# Process-wide cap on Gemini calls per minute (sliding 60s window). Free tier
# gemini-2.5-pro = 5 RPM (set this to 4). Tier 1 = 150+ RPM (set 60–120).
# See https://aistudio.google.com/rate-limit for your actual cap.
GEMINI_MAX_RPM=4

# ---- Database ---------------------------------------------------------

# Leave blank for the default SQLite at ./exam_db.sqlite, or supply a
# Postgres URL like postgresql://user:pass@host:5432/exam_db.
DATABASE_URL=

# ---- Extraction tuning ------------------------------------------------

# Parallel page workers inside one submission. 6 is the sweet spot for one
# backend on a 16+GB host. Higher = faster but more RAM (each worker carries
# a PIL image).
MAX_EXTRACTION_WORKERS=6

# Image preprocessing knobs (improves contrast/clarity before extraction).
ENABLE_IMAGE_PREPROCESSING=True
PREPROCESSING_MODE=balanced     # balanced | aggressive

# Mathpix polling cadence. 3s interval × 600s ceiling = 10 minutes max wait
# before giving up on the diagram overlay.
MATHPIX_POLL_INTERVAL_SECONDS=3.0
MATHPIX_MAX_WAIT_SECONDS=600.0

# ---- App / runtime ----------------------------------------------------

APP_ENV=development
DEBUG=True
LOG_LEVEL=INFO
MAX_FILE_SIZE_MB=50
ALLOWED_EXTENSIONS=.pdf
MINIMAL_OUTPUT=False

# Path to poppler binaries if pdf2image can't find them on PATH (Windows).
# POPPLER_PATH=C:\path\to\poppler\bin

# ---- Optional: DigitalOcean Spaces archive ---------------------------

# When enabled, page images are uploaded to a Spaces bucket as backups.
ARCHIVE_IMAGES_TO_SPACES=False
# SPACES_ENDPOINT=https://sgp1.digitaloceanspaces.com
# SPACES_REGION=sgp1
# SPACES_BUCKET=exam-answer-sheets
# SPACES_KEY=your_spaces_access_key_here
# SPACES_SECRET=your_spaces_secret_key_here
# SPACES_IMAGE_ARCHIVE_FOLDER=exams-extraction-pics
