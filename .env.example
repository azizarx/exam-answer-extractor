# DigitalOcean Spaces Configuration
SPACES_REGION=sgp1
SPACES_ENDPOINT=https://sgp1.digitaloceanspaces.com
SPACES_KEY=your_spaces_access_key_here
SPACES_SECRET=your_spaces_secret_key_here
SPACES_BUCKET=exam-answer-sheets

# Google Gemini Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-pro
GEMINI_FALLBACK_MODELS=gemini-2.0-flash,gemini-2.0-flash-lite
GEMINI_AUTO_FALLBACK=True

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/exam_db

# Redis Configuration (for Celery)
REDIS_URL=redis://localhost:6379/0

# Application Settings
APP_ENV=development
DEBUG=True
LOG_LEVEL=INFO

# Extraction Accuracy Settings
ENABLE_IMAGE_PREPROCESSING=True
PREPROCESSING_MODE=balanced
SAVE_OCR_RESULTS=True
OCR_RESULTS_FOLDER_NAME=OCRResults
OCR_LANGUAGE=eng
# Optional explicit path (recommended on Windows)
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# File Upload Settings
MAX_FILE_SIZE_MB=50
ALLOWED_EXTENSIONS=.pdf
